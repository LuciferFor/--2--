NODE_ENV=development
HOST=0.0.0.0
PORT=3000
HOST_PORT=3000
BUNGIE_API_KEY=replace-with-your-bungie-api-key
BUNGIE_API_BASE_URL=https://www.bungie.net/Platform
CORS_ORIGIN=*
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute
REDIS_URL=redis://redis:6379
DATABASE_URL=postgres://destiny:destiny@postgres:5432/destiny
MANIFEST_LOCALE=zh-chs
MANIFEST_PRELOAD=false
CARD_CACHE_TTL_SECONDS=600
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=replace-with-a-long-random-session-secret
ADMIN_SESSION_TTL_SECONDS=86400
